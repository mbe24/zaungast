{
  "schemaVersion": "teams-2026-07",
  "description": "New Teams (MSTeams/EBWebView) https_teams.microsoft.com IndexedDB. First known-good mapping.",
  "knownFingerprints": ["a76afb2b8e4c05ed"],
  "match": {
    "requireStores": ["replychains", "conversations"]
  },
  "entities": {
    "conversation": {
      "db": "*conversation-manager*",
      "store": "conversations",
      "fields": {
        "id": "id",
        "topic": ["threadProperties.topic", "threadProperties.spaceThreadTopic"],
        "threadType": "threadProperties.threadType",
        "type": "type",
        "teamId": "teamId",
        "lastMessageTimeUtc": "lastMessageTimeUtc"
      }
    },
    "message": {
      "db": "*replychain-manager*",
      "store": "replychains",
      "iterate": "messageMap.*",
      "keep": { "field": "type", "equals": "Message" },
      "fields": {
        "id": "id",
        "conversationId": "conversationId",
        "parentMessageId": "parentMessageId",
        "version": "version",
        "time": ["originalArrivalTime", "composeTime", "clientArrivalTime"],
        "senderId": "creator",
        "senderName": "imDisplayName",
        "messageType": "messageType",
        "contentType": "contentType",
        "content": "content",
        "isSentByCurrentUser": "isSentByCurrentUser",
        "mentions": "properties.mentions",
        "files": "properties.files"
      }
    }
  }
}
