{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    // libzaungast is the publishable library → emit .d.ts (+ maps) so external TS consumers get
    // types via the exports-map `types` condition (→ ./dist/*.d.ts). declaration is off in the
    // shared root config (the private zaungast app doesn't need it). (§B)
    "declaration": true,
    "declarationMap": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
