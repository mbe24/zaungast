{
  "name": "libzaungast",
  "version": "0.4.0",
  "description": "Read-only, offline reader for the local Microsoft Teams cache (Chromium IndexedDB-on-LevelDB): decodes it into clean, structured, query-able data — conversations, messages, people, events, calls. No Graph API, no cloud, no credentials. Not affiliated with or endorsed by Microsoft.",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./format": {
      "development": "./src/format/index.ts",
      "types": "./dist/format/index.d.ts",
      "default": "./dist/format/index.js"
    },
    "./format/engine": {
      "development": "./src/format/engine.ts",
      "types": "./dist/format/engine.d.ts",
      "default": "./dist/format/engine.js"
    },
    "./engine-spi": {
      "development": "./src/engine-spi.ts",
      "types": "./dist/engine-spi.d.ts",
      "default": "./dist/engine-spi.js"
    },
    "./web": {
      "development": "./src/web.ts",
      "types": "./dist/web.d.ts",
      "default": "./dist/web.js"
    },
    "./schema/versions/*.json": {
      "development": "./src/schema/versions/*.json",
      "default": "./dist/schema/versions/*.json"
    }
  },
  "imports": {
    "#bytes": {
      "browser": {
        "development": "./src/util/bytes-web.ts",
        "default": "./dist/util/bytes-web.js"
      },
      "development": "./src/util/bytes-node.ts",
      "default": "./dist/util/bytes-node.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mbe24/zaungast.git",
    "directory": "packages/libzaungast"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-schema.mjs"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "license": "Apache-2.0",
  "keywords": [
    "microsoft-teams",
    "indexeddb",
    "leveldb",
    "offline",
    "read-only"
  ]
}
