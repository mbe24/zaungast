{
  "name": "libzaungast",
  "version": "0.3.0",
  "private": true,
  "description": "Read-only, offline reader for the local Microsoft Teams cache (Chromium IndexedDB-on-LevelDB): decodes it into clean, structured, query-able data — conversations, messages, people, events, calls. No Graph API, no cloud, no credentials. Not affiliated with or endorsed by Microsoft.",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./format": {
      "development": "./src/format/index.ts",
      "types": "./dist/format/index.d.ts",
      "default": "./dist/format/index.js"
    },
    "./format/engine": {
      "development": "./src/format/engine.ts",
      "types": "./dist/format/engine.d.ts",
      "default": "./dist/format/engine.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mbe24/zaungast.git",
    "directory": "packages/libzaungast"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"require('fs').cpSync('src/schema/versions','dist/schema/versions',{recursive:true})\""
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "license": "Apache-2.0",
  "keywords": [
    "microsoft-teams",
    "indexeddb",
    "leveldb",
    "offline",
    "read-only"
  ]
}
