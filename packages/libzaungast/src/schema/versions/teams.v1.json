{
  "mappingVersion": "1.0.0",
  "description": "New Teams (MSTeams/EBWebView) https_teams.microsoft.com IndexedDB. First known-good mapping.",
  "knownFingerprints": ["37938b9e38ad7c79"],
  "match": {
    "requireStores": ["replychains", "conversations"]
  },
  "entities": {
    "conversation": {
      "db": "*conversation-manager*",
      "store": "conversations",
      "fields": {
        "id": "id",
        "topic": ["threadProperties.topic", "threadProperties.spaceThreadTopic"],
        "threadType": "threadProperties.threadType",
        "type": "type",
        "teamId": "teamId",
        "lastMessageTimeUtc": "lastMessageTimeUtc"
      }
    },
    "message": {
      "db": "*replychain-manager*",
      "store": "replychains",
      "iterate": "messageMap.*",
      "keep": { "field": "type", "equals": "Message" },
      "fields": {
        "id": "id",
        "conversationId": "conversationId",
        "parentMessageId": "parentMessageId",
        "version": "version",
        "time": ["originalArrivalTime", "composeTime", "clientArrivalTime"],
        "senderId": "creator",
        "senderName": "imDisplayName",
        "messageType": "messageType",
        "contentType": "contentType",
        "content": "content",
        "isSentByCurrentUser": "isSentByCurrentUser",
        "mentions": "properties.mentions",
        "files": "properties.files",
        "reactions": "properties.emotions"
      }
    },
    "profile": {
      "db": "*profile*",
      "store": "profiles",
      "fields": {
        "mri": "mri",
        "name": "displayName"
      }
    },
    "event": {
      "db": "*calendar*",
      "store": "calendar",
      "fields": {
        "id": "objectId",
        "seriesId": "seriesMasterId",
        "subject": "subject",
        "startTime": "startTime",
        "endTime": "endTime",
        "isAllDay": "isAllDayEvent",
        "location": "location",
        "organizerName": "organizerName",
        "organizerEmail": "organizerAddress",
        "isOnlineMeeting": "isOnlineMeeting",
        "cid": "skypeTeamsDataObject.cid",
        "isAppointment": "isAppointment",
        "myResponse": "myResponseType",
        "showAs": "showAs",
        "isCancelled": "isCancelled",
        "eventType": "eventType",
        "sensitivityLabelId": "sensitivityLabelId",
        "doNotForward": "doNotForward",
        "hasAttachments": "hasAttachments",
        "attendees": "attendees",
        "bodyContent": "bodyContent"
      }
    },
    "call": {
      "db": "*call-history-manager*",
      "store": "call-history",
      "fields": {
        "id": "callId",
        "callType": "callType",
        "callDirection": "callDirection",
        "callState": "callState",
        "startTime": "startTime",
        "durationInMs": "durationInMs",
        "originator": "originatorParticipant",
        "target": "targetParticipant",
        "participantList": "participantList",
        "groupChatThreadId": "groupChatThreadId",
        "recordings": "recordings",
        "transcript": "transcript",
        "voicemailMetadata": "voicemailMetadata",
        "spamRiskLevel": "spamRiskLevel",
        "isCurrentUserPartOfCall": "isCurrentUserPartOfCall",
        "isDeleted": "isDeleted"
      }
    }
  }
}
