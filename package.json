{
  "name": "zaungast-monorepo",
  "version": "0.4.0",
  "private": true,
  "description": "Monorepo for libzaungast (read-only offline Teams-cache reader) and zaungast (its MCP server). Not affiliated with or endorsed by Microsoft.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mbe24/zaungast.git"
  },
  "homepage": "https://github.com/mbe24/zaungast#readme",
  "bugs": "https://github.com/mbe24/zaungast/issues",
  "workspaces": [
    "packages/libzaungast",
    "packages/zaungast",
    "packages/libzaungast-native"
  ],
  "scripts": {
    "build": "npm run build --workspace libzaungast && npm run build --workspace zaungast",
    "start": "node --experimental-sqlite packages/zaungast/dist/index.js",
    "dev": "node --conditions=development --experimental-sqlite --import tsx packages/zaungast/src/index.ts",
    "tsx": "node --conditions=development --experimental-sqlite --import tsx",
    "typecheck": "tsc -p packages/libzaungast/tsconfig.json --noEmit && tsc -p packages/libzaungast-native/tsconfig.json --noEmit && tsc -p packages/zaungast/tsconfig.json --noEmit",
    "typecheck:test": "tsc -p packages/libzaungast/test/tsconfig.json && tsc -p packages/libzaungast-native/test/tsconfig.json && tsc -p packages/zaungast/test/tsconfig.json",
    "check:deps": "node scripts/check-deps.mjs",
    "check:native-triples": "node scripts/check-native-triples.mjs",
    "check:test-naming": "node scripts/check-test-naming.mjs",
    "check:native": "node scripts/check-native.mjs",
    "test:native": "node scripts/native-test.mjs",
    "diff": "node scripts/native-diff.mjs",
    "verify:native": "node scripts/native-verify.mjs",
    "smoke:external-install": "node scripts/smoke-external-install.mjs",
    "format": "prettier --write \"packages/*/src/**/*.ts\" \"packages/*/shim/**/*.ts\" \"packages/*/test/**/*.ts\"",
    "format:check": "prettier --check \"packages/*/src/**/*.ts\" \"packages/*/shim/**/*.ts\" \"packages/*/test/**/*.ts\"",
    "test": "vitest run --project unit",
    "test:watch": "vitest",
    "test:fixture": "vitest run --project fixture",
    "test:integration:ci": "vitest run --project int",
    "test:integration": "vitest run --project int",
    "test:golden": "vitest run --project golden",
    "test:golden:real": "vitest run --project real",
    "test:browser": "vitest run --project browser",
    "check:web-bundle": "node scripts/bundle-smoke.mjs",
    "assets": "node scripts/render-assets.mjs",
    "profile": "node --experimental-sqlite --expose-gc scripts/profile.mjs",
    "profile:native": "node scripts/profile-rust.mjs",
    "profile:compare": "node scripts/profile-compare.mjs",
    "test:schema": "node scripts/test-timings-v1.mjs"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "license": "Apache-2.0",
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@sqlite.org/sqlite-wasm": "^3.53.0-build1",
    "@types/node": "^26.1.1",
    "esbuild": "^0.28.1",
    "happy-dom": "^20.0.0",
    "prettier": "^3.9.5",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
